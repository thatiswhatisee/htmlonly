body{
  display: flex;
    font-size: 100px;
  flex-direction: column;
  justify-content:center;
  align-items: center;
  font-family: "Josefin Sans", sans-serif;
}

header {
	width:100%;
  font-size: 100px;
  font-family: "Josefin Sans", sans-serif;
  font-weight: 400;
  font-style: normal;
  color:white;
  position:sticky;
  top:0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  
}

/* The animation */
@keyframes color-change {
  from {
    color: white;
  }
  25% {
    color: indianred;
  }
  50% {
    color: cadetblue;
  }
  75% {
    color: darkseagreen;
  }
  to {
    color: yellow;
  }
}

/* The element */
h1 {
  color: black;
  animation-name: color-change;
  animation-duration: 15s;
    animation
}

    
